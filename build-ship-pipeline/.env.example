# Copy to .env and fill in real values — .env is gitignored

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Postgres (matches docker/docker-compose.yml defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=build_ship
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline_secret

# OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Optional: log level
LOG_LEVEL=INFO

# UI / Auth (required for the web UI)
SECRET_KEY=replace-with-a-long-random-secret   # REQUIRED: openssl rand -hex 32
SEED_USERNAME=admin
SEED_PASSWORD=changeme   # change before going to production

# CORS: comma-separated origins allowed cross-domain (leave unset in production
# where the SPA and API share the same nginx origin)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Optional: additional LLM providers
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
